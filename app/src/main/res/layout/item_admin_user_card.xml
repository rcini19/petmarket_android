<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="920dp"
    android:layout_height="60dp"
    android:background="@drawable/bg_admin_table_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.55"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingEnd="8dp"
        android:textColor="@color/pm_market_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.9"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingEnd="8dp"
        android:textColor="@color/pm_market_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvRole"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/pm_market_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_weight="0.95"
        android:background="@drawable/bg_green_badge"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textColor="@color/success_600"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvJoined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.7"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:textColor="@color/pm_market_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvActivity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.55"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingEnd="8dp"
        android:textColor="@color/pm_market_text"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnSuspend"
        android:layout_width="86dp"
        android:layout_height="38dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_danger_button"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="@string/suspend"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
