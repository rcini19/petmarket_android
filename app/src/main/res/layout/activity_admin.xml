<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pm_market_bg"
    android:orientation="vertical">

    <include layout="@layout/layout_market_header" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_admin_panel"
            android:textColor="@color/pm_market_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/admin_subtitle"
            android:textColor="@color/pm_market_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnListingsTab"
                android:layout_width="82dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_admin_tab_selected"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/listings"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnUsersTab"
                android:layout_width="72dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_tab_unselected"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/users"
                android:textAllCaps="false"
                android:textColor="@color/pm_market_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:indeterminateTint="@color/pm_market_primary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/listingsStatsPanel"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvTotalListingsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/pm_market_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_total_listings"
                    android:textColor="@color/pm_market_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvListingsRevenueValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textColor="@color/pm_market_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_total_revenue"
                    android:textColor="@color/pm_market_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/usersStatsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_panel_card"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvTotalUsersValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/pm_market_text"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_total_users"
                        android:textColor="@color/pm_market_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_panel_card"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvActiveUsersValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/pm_market_text"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_active_users"
                        android:textColor="@color/pm_market_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_panel_card"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvSuspendedUsersValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/pm_market_text"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_suspended_users"
                        android:textColor="@color/pm_market_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_panel_card"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvUsersRevenueValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textColor="@color/pm_market_text"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_total_revenue"
                        android:textColor="@color/pm_market_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/etUserSearch"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:hint="@string/admin_search_users_hint"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:textColor="@color/pm_market_text"
            android:textColorHint="@color/pm_market_muted"
            android:textSize="12sp"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/listingsTableHeader"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="720dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_admin_table_header"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="2.1" android:text="@string/admin_table_pet" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="1.45" android:text="@string/admin_table_owner" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="0.8" android:text="@string/admin_table_type" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="0.8" android:text="@string/admin_table_price" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="1.0" android:text="@string/admin_table_status" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="90dp" android:text="@string/admin_table_actions" />
            </LinearLayout>
        </HorizontalScrollView>

        <HorizontalScrollView
            android:id="@+id/usersTableHeader"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="920dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_admin_table_header"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="1.55" android:text="@string/admin_table_user" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="1.9" android:text="@string/admin_table_email" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="0.8" android:text="@string/admin_table_role" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="0.95" android:text="@string/admin_table_status" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="0.7" android:text="@string/admin_table_joined" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="0dp" android:layout_weight="1.55" android:text="@string/admin_table_activity" />
                <TextView style="@style/AdminTableHeaderText" android:layout_width="90dp" android:text="@string/admin_table_actions" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvPetsEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/no_admin_pets"
            android:textColor="@color/pm_market_muted"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvUsersEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/no_admin_users"
            android:textColor="@color/pm_market_muted"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/rvPetsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:overScrollMode="never">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPets"
                android:layout_width="720dp"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp" />
        </HorizontalScrollView>

        <HorizontalScrollView
            android:id="@+id/rvUsersContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUsers"
                android:layout_width="920dp"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp" />
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>
